rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Video Entity Validation
    function isValidVideo(video) {
      return video.keys().hasAll(['title', 'url', 'category', 'userId', 'createdAt'])
        && video.keys().size() <= 8
        && video.title is string && video.title.size() <= 100
        && video.url is string && video.url.size() <= 500
        && video.category in ['Installation', 'Troubleshooting', 'Safety', 'Maintenance']
        && video.userId == request.auth.uid
        && video.createdAt == request.time;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'joshua@garageup.com';
    }

    function isApproved() {
      return isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.status == 'approved');
    }

    // Profiles Collection
    match /profiles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && incoming().status == (isAdmin() ? 'approved' : 'pending');
      allow update: if isAdmin() || (isOwner(userId) && incoming().status == existing().status);
      allow delete: if isAdmin();
    }

    // Videos Collection - Update to require approval
    match /videos/{videoId} {
      allow list: if isApproved();
      allow get: if isApproved();
      allow create: if isApproved() 
        && isValidVideo(incoming());
      allow update: if isApproved() 
        && isOwner(existing().userId)
        && isValidVideo(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() 
        && isOwner(existing().userId);
    }
  }
}
